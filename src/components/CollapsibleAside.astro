---
export interface Props {
  title: string;
  isOpen?: boolean;
}

const { title, isOpen = false } = Astro.props;
---

<details class="collapsible-aside" open={isOpen}>
  <summary>
    <span class="title">{title}</span>
  </summary>
  <div class="content">
    <slot />
  </div>
</details>

<style>
  .collapsible-aside {
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 8px;
    margin-block-end: 1.5rem;
    background-color: #1F1F1F;
    padding: 0;
  }

  .collapsible-aside summary {
    display: flex;
    align-items: center;
    cursor: pointer;
    color: #5AC8FA;
    padding: 0.5rem 1.25rem;
    gap: 0.69rem;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .collapsible-aside .title {
    font-weight: 400;
    color: #E5E5E5;
  }

  .collapsible-aside .content {
    padding: 0.75rem 1.25rem;
    padding-top: 0;
    color: #E5E5E5;
  }

  .collapsible-aside .content :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .collapsible-aside .content :global(li) {
    margin: 0;
  }

  .collapsible-aside .content :global(a) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background-color: #242424;
    color: #A1A1A1;
    padding: 0.35rem 0.75rem;
    border-radius: 20px;
    text-decoration: none;
    font-size: 12px;
    font-weight: 400;
    font-family: 'Space Grotesk', sans-serif;
    transition: all 200ms ease;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .collapsible-aside .content :global(a:hover) {
    background-color: rgba(90, 200, 250, 0.1);
    color: #5AC8FA;
    border-color: rgba(90, 200, 250, 0.3);
  }
</style>
