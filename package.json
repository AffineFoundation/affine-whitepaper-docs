{
  "name": "affine-whitepaper-docs",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "convert": "node scripts/convert-whitepaper.mjs",
    "convert:whitepaper": "node scripts/convert-whitepaper.mjs",
    "ingest:subnets": "python3 scripts/ingest-deepwiki.py --url https://deepwiki.com/AffineFoundation/affine-cortex --github https://github.com/AffineFoundation/affine-cortex --output src/content/docs/subnets --prefix subnets",
    "test": "node --test tests/test-conversion.mjs",
    "test:python": "python3 -m pytest tests/test-ingestion.py -v",
    "test:build": "node tests/test-build-output.mjs",
    "test:all": "npm test && npm run test:python && npm run build && npm run test:build"
  },
  "dependencies": {
    "@astrojs/starlight": "0.34.3",
    "astro": "5.6.1",
    "rehype-mermaid": "^3.0.0",
    "sharp": "^0.32.5"
  },
  "devDependencies": {
    "playwright": "^1.52.0"
  },
  "overrides": {
    "zod": "3.25.28",
    "@astrojs/sitemap": "3.4.0"
  }
}
